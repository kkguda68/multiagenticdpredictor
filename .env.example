# -----------------------------------------------------------------------------
# Example environment configuration for the ICD-10 Multi-Agent Predictor.
# Copy to `.env` and fill in real values. NEVER commit a populated `.env`.
# -----------------------------------------------------------------------------

# --- Core GCP ---
GCP_PROJECT_ID=qwiklabs-gcp-03-d9bd89368565
GCP_LOCATION=us-central1

# --- Agent 1: DLP ---
DLP_LOCATION=global
DLP_MIN_LIKELIHOOD=POSSIBLE
DLP_ENABLE_REGEX_FALLBACK=true

# --- Agent 2: local PubMedBERT encoder ---
PUBMEDBERT_MODEL_NAME=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext
PUBMEDBERT_DEVICE=auto
PUBMEDBERT_MAX_LENGTH=512
EMBEDDING_DIM=768
MAX_CONCEPTS=12

# --- Agent 3: BigQuery RAG ---
BQ_DATASET=pathology
BQ_HISTORY_TABLE=historical_transactions
RAG_TOP_K=10
RAG_USE_VECTOR_SEARCH=true

# --- Orchestration: Google ADK ---
ADK_APP_NAME=icd_predictor
ADK_USER_ID=system

# --- Guardrails ---
MAX_INPUT_CHARS=8000
MIN_CONFIDENCE_THRESHOLD=0.0

# --- Operational ---
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=3

# --- Authentication (local dev) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
